{
  "model_id": "Qwen/Qwen3-8B",
  "method": "qlora",
  "data_format": "chat",
  "lora_r": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.05,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "quant_bits": 4,
  "epochs": 3,
  "batch_size": 2,
  "gradient_accumulation_steps": 8,
  "learning_rate": 1e-4,
  "lr_scheduler": "cosine",
  "warmup_ratio": 0.1,
  "weight_decay": 0.01,
  "max_seq_length": 2048,
  "val_split": 0.1,
  "save_steps": 200,
  "eval_steps": 100,
  "early_stopping_patience": 5,
  "bf16": true,
  "gradient_checkpointing": true,
  "merge_adapter": false
}
